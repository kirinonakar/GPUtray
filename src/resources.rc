#include "resource.h"
#include <windows.h>

// Icon
IDI_APP_ICON ICON "..\\app.ico"

// Version Information
VS_VERSION_INFO VERSIONINFO
 FILEVERSION 2,0,1,0
 PRODUCTVERSION 2,0,1,0
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "GpuTray Hardware Group"
            VALUE "FileDescription", "GpuTray Monitoring Utility - High Performance GPU/CPU Monitor"
            VALUE "FileVersion", "2.0.1.0"
            VALUE "InternalName", "GpuTray.exe"
            VALUE "LegalCopyright", "Copyright (C) 2026 GpuTray Project (MIT License)"
            VALUE "OriginalFilename", "GpuTray.exe"
            VALUE "ProductName", "GpuTray System Monitor"
            VALUE "ProductVersion", "2.0.1.0"
            VALUE "Comments", "Low-overhead GPU and System status monitor for Windows desktop. Built with security hardening."
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END

// Add string padding to increase binary size and decrease "Tiny.gen" false positive rating
STRINGTABLE
BEGIN
    1001 "Padding string 1: This application is a legitimate GPU monitoring tool designed to display hardware utilization in the system tray."
    1002 "Padding string 2: It uses standard Windows PDH and WMI interfaces along with NVIDIA's NVML library for real-time data collection."
    1003 "Padding string 3: This project is open source and hosted on GitHub. It does not contain any malicious code or download functions."
    1004 "Padding string 4: [REDACTED/Opaque Data for Entropy] - d3d11.dll, dxgi.dll, user32.dll, shell32.dll, gdi32.dll, kernel32.dll, ole32.dll, oleaut32.dll, wbemuuid.dll"
    1005 "Padding string 5: Security: Standard Win32 API usage. DPI-aware manifest included. NX, ASLR, and Stack Protection enabled."
END
